     </profile>
+
+    <profile>
+      <id>milestone5-pit</id>
+      <properties>
+        <pitest.version>1.15.3</pitest.version>
+        <!-- Initial milestone scope: Gson's streaming subsystem plus JsonStreamParser -->
+        <pitest.target.tests>com.google.gson.*</pitest.target.tests>
+        <pitest.target.class.1>com.google.gson.stream.*</pitest.target.class.1>
+        <pitest.target.class.2>com.google.gson.JsonStreamParser</pitest.target.class.2>
+        <pitest.reports.directory>${project.build.directory}/pit-reports</pitest.reports.directory>
+        <pitest.history.file>${project.build.directory}/pit-history/history.bin</pitest.history.file>
+        <pitest.threads>7</pitest.threads>
+        <pitest.timeout.constant>5000</pitest.timeout.constant>
+        <pitest.withHistory>false</pitest.withHistory>
+        <pitest.verbose>true</pitest.verbose>
+        <pitest.jvm.maxHeap>1024m</pitest.jvm.maxHeap>
+      </properties>
+      <build>
+        <plugins>
+          <plugin>
+            <groupId>org.pitest</groupId>
+            <artifactId>pitest-maven</artifactId>
+            <version>${pitest.version}</version>
+            <configuration>
+              <targetClasses>
+                <param>${pitest.target.class.1}</param>
+                <param>${pitest.target.class.2}</param>
+              </targetClasses>
+              <targetTests>
+                <param>${pitest.target.tests}</param>
+              </targetTests>
+              <excludedTestClasses>
+                <!-- Integration test requires the final packaged JAR and fails under PIT's baseline run -->
+                <param>com.google.gson.integration.*</param>
+              </excludedTestClasses>
+              <mutators>
+                <mutator>DEFAULTS</mutator>
+              </mutators>
+              <outputFormats>
+                <param>HTML</param>
+                <param>XML</param>
+              </outputFormats>
+              <reportsDirectory>${pitest.reports.directory}</reportsDirectory>
+              <historyInputFile>${pitest.history.file}</historyInputFile>
+              <historyOutputFile>${pitest.history.file}</historyOutputFile>
+              <threads>${pitest.threads}</threads>
+              <timeoutConstant>${pitest.timeout.constant}</timeoutConstant>
+              <jvmArgs>
+                <value>-Xmx${pitest.jvm.maxHeap}</value>
+              </jvmArgs>
+              <withHistory>${pitest.withHistory}</withHistory>
+              <timestampedReports>false</timestampedReports>
+              <verbose>${pitest.verbose}</verbose>
+              <failWhenNoMutations>true</failWhenNoMutations>
+            </configuration>
+          </plugin>
+        </plugins>
+      </build>
+    </profile>
   </profiles>
 </project>
